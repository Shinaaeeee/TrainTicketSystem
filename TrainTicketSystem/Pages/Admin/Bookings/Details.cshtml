@page
@model TrainTicketSystem.Pages.Admin.Bookings.DetailsModel
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Booking?.BookingId}";
    Layout = "_Layout";
}

@if (Model.Booking == null)
{
    <div class="alert alert-danger">Không tìm thấy đơn đặt vé.</div>
}
else
{
    var b = Model.Booking;

    <div class="container py-4" style="max-width: 860px;">

        <!-- Back button -->
        <a asp-page="Index" class="btn btn-outline-secondary btn-sm mb-3">← Quay lại</a>

        <!-- ===== BOOKING HEADER CARD ===== -->
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
                <h5 class="mb-0">🎫 Đơn đặt vé #@b.BookingId</h5>
                @{
                    var badgeClass = b.Status switch
                    {
                        "Paid"      => "bg-success",
                        "Pending"   => "bg-warning text-dark",
                        "Cancelled" => "bg-danger",
                        _           => "bg-secondary"
                    };
                }
                <span class="badge @badgeClass fs-6">@b.Status</span>
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <!-- Customer info -->
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase fw-semibold mb-2">Khách hàng</h6>
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-muted" width="120">Họ tên:</td>
                                <td><strong>@b.FullName</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Email:</td>
                                <td>@b.Email</td>
                            </tr>
                            <tr>
                                <td class="text-muted">SĐT:</td>
                                <td>@b.Phone</td>
                            </tr>
                        </table>
                    </div>

                    <!-- Trip info -->
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase fw-semibold mb-2">Thông tin chuyến</h6>
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-muted" width="120">Tàu:</td>
                                <td><strong>@b.TrainName</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Tuyến:</td>
                                <td>@b.StartStation → @b.EndStation</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Khởi hành:</td>
                                <td>@b.DepartureTime.ToString("HH:mm — dd/MM/yyyy")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Đến nơi:</td>
                                <td>@b.ArrivalTime.ToString("HH:mm — dd/MM/yyyy")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Ngày đặt:</td>
                                <td>@b.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== SEAT TABLE ===== -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h6 class="mb-0">💺 Danh sách ghế</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Số ghế</th>
                            <th>Loại ghế</th>
                            <th class="text-end">Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seat in b.Seats)
                        {
                            <tr>
                                <td><strong>@seat.SeatNumber</strong></td>
                                <td>@seat.SeatTypeName</td>
                                <td class="text-end">@seat.Price.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="2" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold text-success fs-5">
                                @b.TotalPrice.ToString("N0") ₫
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- ===== PAYMENT INFO ===== -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h6 class="mb-0">💳 Thanh toán</h6>
            </div>
            <div class="card-body">
                @if (b.PaymentDate.HasValue)
                {
                    <div class="d-flex gap-4">
                        <div>
                            <small class="text-muted">Phương thức</small>
                            <div class="fw-semibold">@b.PaymentMethod</div>
                        </div>
                        <div>
                            <small class="text-muted">Ngày thanh toán</small>
                            <div class="fw-semibold">@b.PaymentDate.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div>
                            <small class="text-muted">Số tiền</small>
                            <div class="fw-semibold text-success">@b.TotalPrice.ToString("N0") ₫</div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">⚠️ Chưa có thông tin thanh toán.</p>
                }
            </div>
        </div>

    </div>
}
