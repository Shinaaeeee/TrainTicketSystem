@page "/Admin"
@model TrainTicketSystem.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml"; // Sử dụng layout Admin đã tạo
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Overview</h1>
    <p class="text-slate-600 mt-2">Welcome to VNR Train Ticket Booking System Admin Dashboard</p>
</div>

<div class="mt-8 bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-slate-900">All Bookings</h2>

        <div class="flex items-center gap-2">
            <a asp-page="/Admin/Index" asp-route-handler="Export" class="inline-flex items-center gap-2 px-3 py-2 bg-green-600 hover:bg-green-700 text-white rounded-md text-sm">
                <i data-lucide="download" class="w-4 h-4"></i>
                <span>Export</span>
            </a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100">
            <thead class="bg-slate-50">
                <tr class="text-sm text-slate-500">
                    <th class="px-3 py-2 text-left">#ID</th>
                    <th class="px-3 py-2 text-left">Customer</th>
                    <th class="px-3 py-2 text-left">Trip</th>
                    <th class="px-3 py-2 text-left">Train</th>
                    <th class="px-3 py-2 text-left">Departure</th>
                    <th class="px-3 py-2 text-right">Total</th>
                    <th class="px-3 py-2 text-left">Status</th>
                    <th class="px-3 py-2 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                @if (Model.Bookings != null && Model.Bookings.Any())
                {
                    foreach (var b in Model.Bookings)
                    {
                        var statusClass = b.Status switch
                        {
                            "Paid" => "bg-emerald-100 text-emerald-800",
                            "Cancelled" => "bg-rose-100 text-rose-800",
                            _ => "bg-slate-100 text-slate-800"
                        };

                        <tr class="text-sm">
                            <td class="px-3 py-3">#@b.BookingId</td>
                            <td class="px-3 py-3">@b.FullName</td>
                            <td class="px-3 py-3">@b.StartStation → @b.EndStation</td>
                            <td class="px-3 py-3">@b.TrainName</td>
                            <td class="px-3 py-3">@b.DepartureTime.ToString("HH:mm dd/MM/yyyy")</td>
                            <td class="px-3 py-3 text-right font-semibold">@b.TotalPrice.ToString("N0") ₫</td>
                            <td class="px-3 py-3">
                                <span class="inline-flex items-center gap-2 px-2 py-1 rounded text-xs font-medium @statusClass">@b.Status</span>
                            </td>
                            <td class="px-3 py-3 text-center">
                                <div class="inline-flex items-center gap-2">
                                    <a asp-page="/Tickets/Details" asp-route-id="@b.BookingId" class="inline-flex items-center gap-2 px-2 py-1 border border-slate-200 rounded text-sm text-slate-700 hover:bg-slate-50">
                                        <i data-lucide="eye" class="w-4 h-4"></i>
                                        <span>View</span>
                                    </a>

                                    @if (!string.Equals(b.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-page-handler="Cancel" class="inline">
                                            <input type="hidden" name="bookingId" value="@b.BookingId" />
                                            <button type="submit" class="inline-flex items-center gap-2 px-2 py-1 bg-rose-600 hover:bg-rose-700 text-white rounded text-sm" onclick="return confirm('Are you sure you want to cancel this booking?');">
                                                <i data-lucide="x-circle" class="w-4 h-4"></i>
                                                <span>Cancel</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="px-3 py-6 text-center text-slate-500">No bookings found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Total Users</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalUsers.ToString("N0")</p>
            </div>
            <div class="bg-blue-100 p-3 rounded-lg">
                <i data-lucide="users" class="text-blue-600 w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Active Trains</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalTrains.ToString("N0")</p>
            </div>
            <div class="bg-green-100 p-3 rounded-lg">
                <i data-lucide="train" class="text-green-600 w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Routes</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalRoutes.ToString("N0")</p>
            </div>
            <div class="bg-purple-100 p-3 rounded-lg">
                <i data-lucide="map-pin" class="text-purple-600 w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Schedules</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalSchedules.ToString("N0")</p>
            </div>
            <div class="bg-amber-100 p-3 rounded-lg">
                <i data-lucide="calendar" class="text-amber-600 w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Available Seats</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalSeats.ToString("N0")</p>
            </div>
            <div class="bg-pink-100 p-3 rounded-lg">
                <i data-lucide="armchair" class="text-pink-600 w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-slate-600 text-sm font-medium">Tickets Sold</p>
                <p class="text-slate-900 text-3xl font-bold mt-2">@Model.TotalTickets.ToString("N0")</p>
            </div>
            <div class="bg-cyan-100 p-3 rounded-lg">
                <i data-lucide="ticket" class="text-cyan-600 w-6 h-6"></i>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Recent Bookings</h2>
        <div class="space-y-4">
            @if (Model.RecentBookings.Any())
            {
                @foreach (var booking in Model.RecentBookings)
                {
                    <div class="flex items-center justify-between py-3 border-b border-slate-100 last:border-0">
                        <div>
                            <p class="font-medium text-slate-900">@booking.CustomerName</p>
                            <p class="text-sm text-slate-600">@booking.RouteInfo</p>
                        </div>
                        <p class="text-xs text-slate-500">@booking.TimeAgo</p>
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-slate-500">No recent bookings found.</p>
            }
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <i data-lucide="trending-up" class="text-green-600 w-5 h-5"></i>
            System Performance
        </h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between py-3 border-b border-slate-100">
                <div>
                    <p class="font-medium text-slate-900">System Uptime</p>
                    <p class="text-xs text-green-600">Excellent</p>
                </div>
                <p class="font-semibold text-slate-900">99.8%</p>
            </div>
            <div class="flex items-center justify-between py-3 border-b border-slate-100">
                <div>
                    <p class="font-medium text-slate-900">Average Response Time</p>
                    <p class="text-xs text-green-600">Good</p>
                </div>
                <p class="font-semibold text-slate-900">245ms</p>
            </div>
            <div class="flex items-center justify-between py-3 border-b border-slate-100">
                <div>
                    <p class="font-medium text-slate-900">Database Load</p>
                    <p class="text-xs text-green-600">Healthy</p>
                </div>
                <p class="font-semibold text-slate-900">35%</p>
            </div>
            <div class="flex items-center justify-between py-3">
                <div>
                    <p class="font-medium text-slate-900">Server CPU</p>
                    <p class="text-xs text-green-600">Normal</p>
                </div>
                <p class="font-semibold text-slate-900">42%</p>
            </div>
        </div>
    </div>
</div>