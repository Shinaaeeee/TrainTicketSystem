@page "{id:int}"
@model TrainTicketSystem.Pages.Tickets.DetailsModel
@{
    ViewData["Title"] = $"Booking #{Model.Booking?.BookingId}";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

@if (Model.Booking == null)
{
    <div class="flex flex-col items-center justify-center py-20 text-slate-500">
        <i data-lucide="alert-triangle" class="w-12 h-12 text-red-400 mb-3"></i>
        <p class="text-lg font-semibold">Booking not found.</p>
        <a asp-page="Index" class="mt-4 text-blue-600 hover:underline text-sm">← Back to list</a>
    </div>
}
else
{
    var b = Model.Booking;

    var (badgeBg, badgeColor) = b.Status switch
    {
        "Paid" => ("bg-green-100 border-green-200", "text-green-700"),
        "Pending" => ("bg-yellow-100 border-yellow-200", "text-yellow-700"),
        "Cancelled" => ("bg-red-100 border-red-200", "text-red-700"),
        _ => ("bg-slate-100 border-slate-200", "text-slate-700")
    };

    <div class="flex items-center justify-between mb-8">
        <div>
            <a asp-page="Index"
               class="text-sm text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2 transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Booking List
            </a>
            <h1 class="text-3xl font-bold text-slate-900">Booking #@b.BookingId</h1>
        </div>
        <span class="px-4 py-1.5 rounded-full text-sm font-semibold border @badgeBg @badgeColor">
            @b.Status
        </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

        @* ── Customer info ── *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i data-lucide="user" class="w-4 h-4"></i> Customer
            </h2>
            <div class="space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Full Name</span>
                    <span class="font-semibold text-slate-900">@b.FullName</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Email</span>
                    <span class="text-slate-700">@(string.IsNullOrEmpty(b.Email) ? "—" : b.Email)</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Phone</span>
                    <span class="text-slate-700">@(string.IsNullOrEmpty(b.Phone) ? "—" : b.Phone)</span>
                </div>
            </div>
        </div>

        @* ── Trip info ── *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i data-lucide="train" class="w-4 h-4"></i> Trip Info
            </h2>
            <div class="space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Train</span>
                    <span class="font-semibold text-slate-900">@b.TrainName</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Route</span>
                    <span class="text-slate-700">@b.StartStation → @b.EndStation</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Departure</span>
                    <span class="text-slate-700">@b.DepartureTime.ToString("HH:mm — dd/MM/yyyy")</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Arrival</span>
                    <span class="text-slate-700">@b.ArrivalTime.ToString("HH:mm — dd/MM/yyyy")</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Booked On</span>
                    <span class="text-slate-700">@b.BookingDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>
    </div>

    @* ── Seats table ── *@
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center gap-2">
            <i data-lucide="armchair" class="w-5 h-5 text-slate-500"></i>
            <h2 class="font-semibold text-slate-900">Seat List</h2>
        </div>
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="py-3 px-6 font-semibold text-slate-700 text-sm">Seat Number</th>
                    <th class="py-3 px-6 font-semibold text-slate-700 text-sm">Seat Type</th>
                    <th class="py-3 px-6 font-semibold text-slate-700 text-sm text-right">Price</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @foreach (var seat in b.Seats)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="py-3 px-6 font-mono font-semibold text-slate-900">@seat.SeatNumber</td>
                        <td class="py-3 px-6 text-slate-700">@seat.SeatTypeName</td>
                        <td class="py-3 px-6 text-right text-slate-700">@seat.Price.ToString("N0") ₫</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="bg-slate-50 border-t border-slate-200">
                    <td colspan="2" class="py-3 px-6 text-right font-bold text-slate-700">Total:</td>
                    <td class="py-3 px-6 text-right font-bold text-green-600 text-base">
                        @b.TotalPrice.ToString("N0") ₫
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>

    @* ── Payment info ── *@
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4 flex items-center gap-2">
            <i data-lucide="credit-card" class="w-4 h-4"></i> Payment
        </h2>
        @if (b.PaymentDate.HasValue)
        {
            <div class="flex flex-wrap gap-8">
                <div>
                    <p class="text-xs text-slate-500 mb-1">Method</p>
                    <p class="font-semibold text-slate-900">@b.PaymentMethod</p>
                </div>
                <div>
                    <p class="text-xs text-slate-500 mb-1">Payment Date</p>
                    <p class="font-semibold text-slate-900">@b.PaymentDate.Value.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div>
                    <p class="text-xs text-slate-500 mb-1">Amount</p>
                    <p class="font-semibold text-green-600">@b.TotalPrice.ToString("N0") ₫</p>
                </div>
            </div>
        }
        else
        {
            <div class="flex items-center gap-2 text-slate-500 text-sm">
                <i data-lucide="alert-circle" class="w-4 h-4 text-yellow-500"></i>
                No payment information yet.
            </div>
        }
    </div>
}