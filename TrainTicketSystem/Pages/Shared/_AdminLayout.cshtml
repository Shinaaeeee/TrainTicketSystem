<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VNR Train Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
</head>
<body class="bg-slate-50 font-sans text-slate-900 antialiased overflow-x-hidden">

    @{
        // Cách lấy context an toàn tuyệt đối không gây lỗi
        var currentPage = Context.Request.Path.ToString();
    }

    <aside class="fixed left-0 top-0 w-64 h-screen bg-slate-900 text-white flex flex-col z-20">
        <div class="p-6 border-b border-slate-700">
            <a href="/Admin" class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                    <i data-lucide="train" class="text-white w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="font-bold text-lg">VNR Train</h1>
                    <p class="text-xs text-slate-400">Admin Dashboard</p>
                </div>
            </a>
        </div>

        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a asp-page="/Admin/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage == "/Admin/Index" || currentPage == "/Admin" ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="home" class="w-5 h-5"></i>
                <span>Overview</span>
            </a>

            <a asp-page="/Trains/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Trains") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="train" class="w-5 h-5"></i>
                <span>Train Management</span>
            </a>

            <a asp-page="/Routes/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Routes") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="map" class="w-5 h-5"></i>
                <span>Route Management</span>
            </a>

            <a asp-page="/Schedules/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Schedules") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="calendar" class="w-5 h-5"></i>
                <span>Schedule Management</span>
            </a>

            <a asp-page="/Seats/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Seats") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="armchair" class="w-5 h-5"></i>
                <span>Seat Management</span>
            </a>

            <a asp-page="/Tickets/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Tickets") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="ticket" class="w-5 h-5"></i>
                <span>Ticket Management</span>
            </a>

            <a asp-page="/Revenue/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Revenue") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="bar-chart-2" class="w-5 h-5"></i>
                <span>Revenue Statistics</span>
            </a>

            <a asp-page="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors @(currentPage.Contains("/Admin/Users") ? "bg-blue-600 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="users" class="w-5 h-5"></i>
                <span>User Management</span>
            </a>
        </nav>

        <div class="p-4 border-t border-slate-700">
            <a asp-page="/Logout" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg text-sm font-medium text-slate-300 hover:bg-slate-800 hover:text-white transition-colors">
                <i data-lucide="log-out" class="w-5 h-5"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <style>
        @@keyframes slideInRight {
            from { transform: translateX(40px); opacity: 0; }
            to   { transform: translateX(0);    opacity: 1; }
        }
        @@keyframes fadeOut {
            from { opacity: 1; max-height: 80px; margin-bottom: 8px; padding: 8px 12px; }
            to   { opacity: 0; max-height: 0;    margin-bottom: 0;  padding: 0 12px; }
        }
        @@keyframes pulseGreen {
            0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,.6); }
            50%      { box-shadow: 0 0 0 4px rgba(34,197,94,.0); }
        }
        .notif-item { animation: slideInRight .4s ease-out; overflow: hidden; }
        .notif-item.removing { animation: fadeOut .5s ease-in forwards; }
        .live-dot { animation: pulseGreen 1.5s ease-in-out infinite; }
    </style>

    <header class="fixed top-0 left-64 right-0 h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 z-10">
        <div class="flex-1 max-w-md">
            <div class="relative">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-4 h-4"></i>
                <input type="text" placeholder="Search..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg text-sm bg-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
            </div>
        </div>

        <!-- ====== INLINE BOOKING NOTIFICATION PANEL ====== -->
        <div class="flex items-center gap-3 mx-4 flex-1 max-w-xl">
            <!-- Live indicator -->
            <div class="flex items-center gap-2 shrink-0">
                <span id="liveDot" class="w-2.5 h-2.5 bg-green-500 rounded-full live-dot" title="Real-time connected"></span>
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Live</span>
            </div>

            <!-- Notification items container -->
            <div id="bookingNotifications" class="flex-1 flex flex-col gap-0 overflow-hidden max-h-14">
                <div id="emptyNotif" class="text-xs text-slate-400 italic px-3 py-1">Chưa có đặt vé mới...</div>
            </div>
        </div>
        <!-- =============================================== -->

        <div class="flex items-center gap-6 ml-4 shrink-0">
            <div class="w-10 h-10 rounded-full bg-slate-200 overflow-hidden border border-slate-300 cursor-pointer">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Admin" alt="Admin" class="w-full h-full object-cover" />
            </div>

            <a asp-page="/Logout" class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
                <i data-lucide="log-out" class="w-4 h-4"></i>
                <span>Logout</span>
            </a>
        </div>
    </header>

    <main class="ml-64 mt-16 p-8">
        @RenderBody()
    </main>

    <script>
        lucide.createIcons();

        // ---- SignalR: Real-time booking notifications ----
        (function () {
            const MAX_VISIBLE = 3;
            const AUTO_DISMISS_MS = 30000; // 30 seconds
            const container = document.getElementById('bookingNotifications');
            const emptyMsg  = document.getElementById('emptyNotif');
            const liveDot   = document.getElementById('liveDot');
            let notifCount = 0;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/bookingNotificationHub')
                .withAutomaticReconnect()
                .build();

            connection.on('ReceiveBookingNotification', function (data) {
                // Hide empty message
                if (emptyMsg) emptyMsg.style.display = 'none';

                // Build notification element
                const el = document.createElement('div');
                el.className = 'notif-item flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-200 rounded-lg text-xs';
                el.innerHTML =
                    '<svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
                    '  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>' +
                    '</svg>' +
                    '<span class="font-semibold text-emerald-700">' + escapeHtml(data.time) + '</span>' +
                    '<span class="text-slate-600 truncate">' +
                        '<strong>' + escapeHtml(data.customerName) + '</strong>' +
                        ' đặt vé ' +
                        '<span class="text-blue-600 font-medium">' + escapeHtml(data.routeName) + '</span>' +
                    '</span>';

                // Insert at the top
                container.insertBefore(el, container.firstChild);
                notifCount++;

                // Remove old ones if exceeding max
                while (container.children.length > MAX_VISIBLE + 1) {
                    // +1 for emptyMsg (hidden)
                    const last = container.lastElementChild;
                    if (last && last.id !== 'emptyNotif') {
                        last.remove();
                        notifCount--;
                    } else break;
                }

                // Auto-dismiss after timeout
                setTimeout(function () {
                    el.classList.add('removing');
                    el.addEventListener('animationend', function () {
                        el.remove();
                        notifCount--;
                        if (notifCount <= 0) {
                            notifCount = 0;
                            if (emptyMsg) emptyMsg.style.display = '';
                        }
                    });
                }, AUTO_DISMISS_MS);
            });

            // Connection state visual feedback
            connection.onreconnecting(function () {
                liveDot.classList.remove('bg-green-500');
                liveDot.classList.add('bg-yellow-500');
            });
            connection.onreconnected(function () {
                liveDot.classList.remove('bg-yellow-500');
                liveDot.classList.add('bg-green-500');
            });
            connection.onclose(function () {
                liveDot.classList.remove('bg-green-500', 'bg-yellow-500');
                liveDot.classList.add('bg-red-500');
            });

            connection.start()
                .then(function () {
                    return connection.invoke('JoinAdminGroup');
                })
                .then(function () {
                    console.log('[BookingNotification] Connected & joined admin group');
                })
                .catch(function (err) {
                    console.error('[BookingNotification] Connection failed:', err);
                    liveDot.classList.remove('bg-green-500');
                    liveDot.classList.add('bg-red-500');
                });

            function escapeHtml(str) {
                var div = document.createElement('div');
                div.textContent = str || '';
                return div.innerHTML;
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>