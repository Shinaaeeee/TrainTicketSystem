@page
@model TrainTicketSystem.Pages.MyTickets.IndexModel
@{
    ViewData["Title"] = "My Tickets";
    Layout = "~/Pages/Shared/UserLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="h4 mb-0">My Bookings</h2>
    <div>
        <a href="?handler=Export" class="btn btn-sm btn-success">Export to Excel</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-3">
        <div class="table-responsive">
            <table class="table table-borderless mb-0">
                <thead>
                    <tr class="small text-muted">
                        <th>#ID</th>
                        <th>Trip</th>
                        <th>Train</th>
                        <th>Departure</th>
                        <th>Booked On</th>
                        <th class="text-end">Total</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Bookings != null && Model.Bookings.Any())
                    {
                        foreach (var b in Model.Bookings)
                        {
                            var badge = b.Status switch
                            {
                                "Paid" => "success",
                                "Cancelled" => "danger",
                                _ => "secondary"
                            };

                            <tr>
                                <td class="align-middle">#@b.BookingId</td>
                                <td class="align-middle">@b.StartStation → @b.EndStation</td>
                                <td class="align-middle">@b.TrainName</td>
                                <td class="align-middle small">@b.DepartureTime.ToString("HH:mm dd/MM/yyyy")</td>
                                <td class="align-middle small">@b.BookingDate.ToString("HH:mm:ss dd/MM/yyyy")</td>
                                <td class="align-middle text-end fw-semibold">@b.TotalPrice.ToString("N0") ₫</td>
                                <td class="align-middle">
                                    <span class="badge bg-@badge text-capitalize">@b.Status</span>
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-page="/Tickets/Details" asp-route-id="@b.BookingId" class="btn btn-sm btn-outline-primary" title="View">
                                            View
                                        </a>

                                        @if (!string.Equals(b.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <form method="post" asp-page-handler="Cancel" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Cancel</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                You have no bookings yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ═══ STYLES ═══ -->
<style>
    .mt-page {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 1rem 4rem;
        font-family: 'Segoe UI', -apple-system, sans-serif;
    }

    /* ── Hero ── */
    .mt-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 20px;
        margin: 1.5rem 0;
        padding: 2rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .mt-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 25% 50%, rgba(14,165,233,.12) 0%, transparent 50%),
                    radial-gradient(circle at 75% 50%, rgba(99,102,241,.1) 0%, transparent 50%);
        pointer-events: none;
    }
    .mt-hero-inner { position: relative; z-index: 1; }
    .mt-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(255,255,255,.1);
        color: #93c5fd;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 100px;
        padding: .3rem .8rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .02em;
        margin-bottom: .6rem;
        backdrop-filter: blur(10px);
    }
    .mt-hero-title {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 .3rem;
    }
    .mt-hero-sub { color: #94a3b8; font-size: .88rem; margin: 0; }

    /* ── Toolbar ── */
    .mt-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }
    .mt-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .82rem;
        font-weight: 600;
        color: #64748b;
        background: #f1f5f9;
        border-radius: 100px;
        padding: .3rem .8rem;
    }
    .mt-count-badge svg { color: #94a3b8; }
    .mt-export-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        background: #065f46;
        color: #fff;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
    }
    .mt-export-btn:hover {
        background: #047857;
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(6,95,70,.25);
    }

    /* ── Booking Cards ── */
    .mt-list { display: flex; flex-direction: column; gap: .75rem; }

    .mt-card {
        background: #fff;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: all .2s;
    }
    .mt-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,.07);
        transform: translateY(-1px);
    }
    .mt-card.cancelled { opacity: .7; }

    /* Card Top */
    .mt-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .85rem;
        padding-bottom: .85rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .mt-id-wrap { display: flex; align-items: center; gap: .75rem; }
    .mt-id {
        font-weight: 800;
        color: #1e293b;
        font-size: .95rem;
        letter-spacing: -.01em;
    }
    .mt-booked-on {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .72rem;
        color: #94a3b8;
    }

    /* Status badge */
    .mt-status {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .65rem;
        border-radius: 100px;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }
    .mt-status.paid { background: #dcfce7; color: #166534; }
    .mt-status.cancelled { background: #fee2e2; color: #991b1b; }
    .mt-status.pending { background: #f1f5f9; color: #64748b; }

    /* Card Route */
    .mt-card-route {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .mt-train-icon-wrap {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: #93c5fd;
        flex-shrink: 0;
    }
    .mt-route-detail { flex: 1; }

    /* Route row */
    .mt-route-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .5rem;
    }
    .mt-station { text-align: center; min-width: 60px; }
    .mt-station-name { display: block; font-weight: 700; color: #1e293b; font-size: .92rem; }
    .mt-station-label { display: block; font-size: .65rem; color: #94a3b8; text-transform: uppercase; letter-spacing: .04em; }
    .mt-route-arrow {
        display: flex;
        align-items: center;
        gap: .15rem;
        flex: 1;
        color: #94a3b8;
    }
    .mt-arrow-line {
        flex: 1;
        height: 2px;
        background: linear-gradient(90deg, #cbd5e1, #94a3b8);
        border-radius: 2px;
    }

    /* Chips */
    .mt-chips { display: flex; gap: .4rem; flex-wrap: wrap; }
    .mt-chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: .15rem .5rem;
        font-size: .72rem;
        color: #64748b;
        font-weight: 500;
    }
    .mt-chip svg { color: #94a3b8; }

    /* Card Bottom */
    .mt-card-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: .85rem;
        border-top: 1px solid #f1f5f9;
    }
    .mt-price { display: flex; flex-direction: column; }
    .mt-price-label { font-size: .68rem; color: #94a3b8; text-transform: uppercase; letter-spacing: .04em; }
    .mt-price-value {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0ea5e9;
    }
    .mt-price-value small { font-size: .75rem; font-weight: 600; color: #94a3b8; }

    /* Action Buttons */
    .mt-actions { display: flex; gap: .5rem; align-items: center; }
    .mt-btn-view {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .4rem .9rem;
        border: 1.5px solid #cbd5e1;
        border-radius: 8px;
        color: #475569;
        font-size: .8rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .15s;
        background: #fff;
    }
    .mt-btn-view:hover {
        background: #f1f5f9;
        border-color: #94a3b8;
        color: #1e293b;
    }
    .mt-btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .4rem .9rem;
        border: 1.5px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        font-size: .8rem;
        font-weight: 600;
        background: #fff;
        cursor: pointer;
        transition: all .15s;
    }
    .mt-btn-cancel:hover {
        background: #fef2f2;
        border-color: #f87171;
    }

    /* ── Empty State ── */
    .mt-empty {
        text-align: center;
        padding: 3.5rem 1rem;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }
    .mt-empty-icon { color: #cbd5e1; margin-bottom: 1rem; }
    .mt-empty h3 { font-size: 1.1rem; font-weight: 700; color: #1e293b; margin: 0 0 .35rem; }
    .mt-empty p { color: #64748b; font-size: .88rem; margin: 0 0 1.25rem; }
    .mt-empty-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.4rem;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: #fff;
        border-radius: 8px;
        font-weight: 700;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
    }
    .mt-empty-btn:hover {
        box-shadow: 0 4px 16px rgba(26,26,46,.3);
        transform: translateY(-1px);
        color: #fff;
    }

    /* ── Responsive ── */
    @@media (max-width: 640px) {
        .mt-card-route { flex-direction: column; align-items: flex-start; }
        .mt-route-row { width: 100%; }
        .mt-card-bottom { flex-direction: column; gap: .75rem; align-items: flex-start; }
        .mt-card-top { flex-direction: column; gap: .5rem; align-items: flex-start; }
        .mt-hero-title { font-size: 1.3rem; }
        .mt-toolbar { flex-direction: column; gap: .5rem; align-items: flex-start; }
    }
</style>
