@page
@model TrainTicketSystem.Pages.MyTickets.IndexModel
@{
    ViewData["Title"] = "Vé của tôi";
    Layout = "~/Pages/Shared/_CustomerLayout.cshtml";
}

<div class="mt-page">

    <!-- ═══ HERO ═══ -->
    <section class="mt-hero">
        <div class="mt-hero-inner">
            <div class="mt-hero-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 5l-1 1"/><path d="M2 12h20"/><rect x="2" y="5" width="20" height="14" rx="2"/></svg>
                Quản lý vé
            </div>
            <h1 class="mt-hero-title">Vé đã đặt</h1>
            <p class="mt-hero-sub">Xem lịch sử đặt vé, theo dõi trạng thái và quản lý các chuyến đi của bạn</p>
        </div>
    </section>

    <!-- ═══ TOOLBAR ═══ -->
    <div class="mt-toolbar">
        <div class="mt-toolbar-left">
            <span class="mt-count-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H2v7l6.29 6.29c.94.94 2.48.94 3.42 0l3.58-3.58c.94-.94.94-2.48 0-3.42L9 5z"/><circle cx="6" cy="9" r="1"/></svg>
                @(Model.Bookings?.Count ?? 0) đơn đặt vé
            </span>
        </div>
        <a href="?handler=Export" class="mt-export-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Xuất Excel
        </a>
    </div>

    <!-- ═══ BOOKING LIST ═══ -->
    @if (Model.Bookings != null && Model.Bookings.Any())
    {
        <div class="mt-list">
            @foreach (var b in Model.Bookings)
            {
                var statusClass = b.Status switch
                {
                    "Paid" => "paid",
                    "Cancelled" => "cancelled",
                    _ => "pending"
                };
                var statusLabel = b.Status switch
                {
                    "Paid" => "Đã thanh toán",
                    "Cancelled" => "Đã hủy",
                    _ => b.Status ?? "Chờ xử lý"
                };

                <div class="mt-card @statusClass">
                    <!-- Top Row: ID + Status -->
                    <div class="mt-card-top">
                        <div class="mt-id-wrap">
                            <span class="mt-id">#@b.BookingId</span>
                            <span class="mt-booked-on">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                @b.BookingDate.ToString("HH:mm dd/MM/yyyy")
                            </span>
                        </div>
                        <span class="mt-status @statusClass">
                            @if (b.Status == "Paid")
                            {
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            }
                            else if (b.Status == "Cancelled")
                            {
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            }
                            else
                            {
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            }
                            @statusLabel
                        </span>
                    </div>

                    <!-- Route Row -->
                    <div class="mt-card-route">
                        <div class="mt-train-icon-wrap">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2c-4 0-8 .5-8 4v9.5C4 17.43 5.57 19 7.5 19L6 20.5v.5h2l2-2h4l2 2h2v-.5L16.5 19c1.93 0 3.5-1.57 3.5-3.5V6c0-3.5-3.58-4-8-4z"/>
                            </svg>
                        </div>

                        <div class="mt-route-detail">
                            <div class="mt-route-row">
                                <div class="mt-station">
                                    <span class="mt-station-name">@b.StartStation</span>
                                    <span class="mt-station-label">Ga đi</span>
                                </div>
                                <div class="mt-route-arrow">
                                    <div class="mt-arrow-line"></div>
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    <div class="mt-arrow-line"></div>
                                </div>
                                <div class="mt-station">
                                    <span class="mt-station-name">@b.EndStation</span>
                                    <span class="mt-station-label">Ga đến</span>
                                </div>
                            </div>

                            <div class="mt-chips">
                                <span class="mt-chip">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c-4 0-8 .5-8 4v9.5C4 17.43 5.57 19 7.5 19L6 20.5v.5h2l2-2h4l2 2h2v-.5L16.5 19c1.93 0 3.5-1.57 3.5-3.5V6c0-3.5-3.58-4-8-4z"/></svg>
                                    @b.TrainName
                                </span>
                                <span class="mt-chip">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    @b.DepartureTime.ToString("HH:mm")
                                </span>
                                <span class="mt-chip">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    @b.DepartureTime.ToString("dd/MM/yyyy")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Row: Price + Actions -->
                    <div class="mt-card-bottom">
                        <div class="mt-price">
                            <span class="mt-price-label">Tổng tiền</span>
                            <span class="mt-price-value">@b.TotalPrice.ToString("N0") <small>₫</small></span>
                        </div>
                        <div class="mt-actions">
                            <a asp-page="/MyTickets/Details" asp-route-id="@b.BookingId" class="mt-btn-view">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                Chi tiết
                            </a>
                            @if (!string.Equals(b.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                            {
                                <form method="post" asp-page-handler="Cancel" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn hủy đơn đặt vé này?');">
                                    <input type="hidden" name="bookingId" value="@b.BookingId" />
                                    <button type="submit" class="mt-btn-cancel">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        Hủy vé
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="mt-empty">
            <div class="mt-empty-icon">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                    <rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M7 15h.01"/><path d="M11 15h2"/>
                </svg>
            </div>
            <h3>Chưa có đơn đặt vé nào</h3>
            <p>Hãy tìm chuyến tàu phù hợp và đặt vé ngay!</p>
            <a href="/" class="mt-empty-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Tìm chuyến tàu
            </a>
        </div>
    }
</div>

<!-- ═══ STYLES ═══ -->
<style>
    .mt-page {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 1rem 4rem;
        font-family: 'Segoe UI', -apple-system, sans-serif;
    }

    /* ── Hero ── */
    .mt-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 20px;
        margin: 1.5rem 0;
        padding: 2rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .mt-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 25% 50%, rgba(14,165,233,.12) 0%, transparent 50%),
                    radial-gradient(circle at 75% 50%, rgba(99,102,241,.1) 0%, transparent 50%);
        pointer-events: none;
    }
    .mt-hero-inner { position: relative; z-index: 1; }
    .mt-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(255,255,255,.1);
        color: #93c5fd;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 100px;
        padding: .3rem .8rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .02em;
        margin-bottom: .6rem;
        backdrop-filter: blur(10px);
    }
    .mt-hero-title {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 .3rem;
    }
    .mt-hero-sub { color: #94a3b8; font-size: .88rem; margin: 0; }

    /* ── Toolbar ── */
    .mt-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }
    .mt-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .82rem;
        font-weight: 600;
        color: #64748b;
        background: #f1f5f9;
        border-radius: 100px;
        padding: .3rem .8rem;
    }
    .mt-count-badge svg { color: #94a3b8; }
    .mt-export-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        background: #065f46;
        color: #fff;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
    }
    .mt-export-btn:hover {
        background: #047857;
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(6,95,70,.25);
    }

    /* ── Booking Cards ── */
    .mt-list { display: flex; flex-direction: column; gap: .75rem; }

    .mt-card {
        background: #fff;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: all .2s;
    }
    .mt-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,.07);
        transform: translateY(-1px);
    }
    .mt-card.cancelled { opacity: .7; }

    /* Card Top */
    .mt-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .85rem;
        padding-bottom: .85rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .mt-id-wrap { display: flex; align-items: center; gap: .75rem; }
    .mt-id {
        font-weight: 800;
        color: #1e293b;
        font-size: .95rem;
        letter-spacing: -.01em;
    }
    .mt-booked-on {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .72rem;
        color: #94a3b8;
    }

    /* Status badge */
    .mt-status {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .65rem;
        border-radius: 100px;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }
    .mt-status.paid { background: #dcfce7; color: #166534; }
    .mt-status.cancelled { background: #fee2e2; color: #991b1b; }
    .mt-status.pending { background: #f1f5f9; color: #64748b; }

    /* Card Route */
    .mt-card-route {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .mt-train-icon-wrap {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: #93c5fd;
        flex-shrink: 0;
    }
    .mt-route-detail { flex: 1; }

    /* Route row */
    .mt-route-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .5rem;
    }
    .mt-station { text-align: center; min-width: 60px; }
    .mt-station-name { display: block; font-weight: 700; color: #1e293b; font-size: .92rem; }
    .mt-station-label { display: block; font-size: .65rem; color: #94a3b8; text-transform: uppercase; letter-spacing: .04em; }
    .mt-route-arrow {
        display: flex;
        align-items: center;
        gap: .15rem;
        flex: 1;
        color: #94a3b8;
    }
    .mt-arrow-line {
        flex: 1;
        height: 2px;
        background: linear-gradient(90deg, #cbd5e1, #94a3b8);
        border-radius: 2px;
    }

    /* Chips */
    .mt-chips { display: flex; gap: .4rem; flex-wrap: wrap; }
    .mt-chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: .15rem .5rem;
        font-size: .72rem;
        color: #64748b;
        font-weight: 500;
    }
    .mt-chip svg { color: #94a3b8; }

    /* Card Bottom */
    .mt-card-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: .85rem;
        border-top: 1px solid #f1f5f9;
    }
    .mt-price { display: flex; flex-direction: column; }
    .mt-price-label { font-size: .68rem; color: #94a3b8; text-transform: uppercase; letter-spacing: .04em; }
    .mt-price-value {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0ea5e9;
    }
    .mt-price-value small { font-size: .75rem; font-weight: 600; color: #94a3b8; }

    /* Action Buttons */
    .mt-actions { display: flex; gap: .5rem; align-items: center; }
    .mt-btn-view {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .4rem .9rem;
        border: 1.5px solid #cbd5e1;
        border-radius: 8px;
        color: #475569;
        font-size: .8rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .15s;
        background: #fff;
    }
    .mt-btn-view:hover {
        background: #f1f5f9;
        border-color: #94a3b8;
        color: #1e293b;
    }
    .mt-btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .4rem .9rem;
        border: 1.5px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        font-size: .8rem;
        font-weight: 600;
        background: #fff;
        cursor: pointer;
        transition: all .15s;
    }
    .mt-btn-cancel:hover {
        background: #fef2f2;
        border-color: #f87171;
    }

    /* ── Empty State ── */
    .mt-empty {
        text-align: center;
        padding: 3.5rem 1rem;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }
    .mt-empty-icon { color: #cbd5e1; margin-bottom: 1rem; }
    .mt-empty h3 { font-size: 1.1rem; font-weight: 700; color: #1e293b; margin: 0 0 .35rem; }
    .mt-empty p { color: #64748b; font-size: .88rem; margin: 0 0 1.25rem; }
    .mt-empty-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.4rem;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: #fff;
        border-radius: 8px;
        font-weight: 700;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
    }
    .mt-empty-btn:hover {
        box-shadow: 0 4px 16px rgba(26,26,46,.3);
        transform: translateY(-1px);
        color: #fff;
    }

    /* ── Responsive ── */
    @@media (max-width: 640px) {
        .mt-card-route { flex-direction: column; align-items: flex-start; }
        .mt-route-row { width: 100%; }
        .mt-card-bottom { flex-direction: column; gap: .75rem; align-items: flex-start; }
        .mt-card-top { flex-direction: column; gap: .5rem; align-items: flex-start; }
        .mt-hero-title { font-size: 1.3rem; }
        .mt-toolbar { flex-direction: column; gap: .5rem; align-items: flex-start; }
    }
</style>
