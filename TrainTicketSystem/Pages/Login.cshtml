@page
@model TrainTicketSystem.Pages.LoginModel

@{
    ViewData["Title"] = "Train Ticket System - Login";
}

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1>🚆 Train Ticket Booking System</h1>
        <p class="text-muted">Login to continue</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4">

            <div class="card shadow-lg">

                <div class="card-header bg-primary text-white text-center">
                    <h4>Login</h4>
                </div>

                <div class="card-body">

                    <form method="post">

                        <div class="mb-3">
                            <label>Username</label>
                            <input asp-for="Username" class="form-control" placeholder="Enter username" />
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                Login
                            </button>
                        </div>

                    </form>

                    <p class="text-danger mt-3">@Model.Message</p>
                    <p class="text-danger mt-3">@Model.Message</p>

                    <div class="text-center mt-3">
                        Don't have an account?
                        <a href="/Register" class="fw-bold text-decoration-none">
                            Register
                        </a>
                    </div>
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success text-center">
                            @TempData["SuccessMessage"]
                        </div>
                    }
                </div>

            </div>

        </div>
    </div>

</div>