@page
@model TrainTicketSystem.Pages.Payment.SuccessModel
@{
    ViewData["Title"] = "Đặt vé thành công";
    Layout = "~/Pages/Shared/_CustomerLayout.cshtml";
}

<div class="result-wrapper">

    <div class="result-card success-card">
        <div class="result-icon">
            <svg viewBox="0 0 52 52" class="checkmark">
                <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
                <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
            </svg>
        </div>

        <h1>Đặt vé thành công!</h1>
        <p class="result-subtitle">Cảm ơn bạn. Vé của bạn đã được xác nhận.</p>

        @if (Model.Booking != null)
        {
            <div class="booking-id-badge">
                Mã đặt vé: <strong>#@Model.Booking.BookingId</strong>
            </div>

            <div class="ticket-summary">
                <div class="ticket-row">
                    <span class="ticket-label">🚂 Tàu</span>
                    <span>@Model.Booking.Schedule?.Train?.TrainName</span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">📍 Tuyến</span>
                    <span>@Model.Booking.Schedule?.Route?.StartStation → @Model.Booking.Schedule?.Route?.EndStation</span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">🕐 Khởi hành</span>
                    <span>@Model.Booking.Schedule?.DepartureTime?.ToString("HH:mm - dd/MM/yyyy")</span>
                </div>
            </div>

            @if (Model.Details.Any())
            {
                <div class="seat-list">
                    <div class="seat-list-title">🎫 Danh sách vé</div>
                    @foreach (var d in Model.Details)
                    {
                        <div class="seat-ticket-item">
                            <div class="seat-info">
                                <span class="seat-num">💺 Ghế @d.Seat?.SeatNumber</span>
                                <span class="seat-type">@d.Seat?.SeatType?.TypeName</span>
                            </div>
                            <div class="passenger-info">
                                <span>👤 @(d.PassengerName ?? "—")</span>
                                <span>📞 @(d.PassengerPhone ?? "—")</span>
                            </div>
                            <div class="seat-price-tag">@d.Price?.ToString("N0") VNĐ</div>
                        </div>
                    }
                </div>
            }

            <div class="payment-total">
                <span>Tổng đã thanh toán</span>
                <strong>@Model.Booking.TotalPrice?.ToString("N0") VNĐ</strong>
            </div>
            @if (Model.Payment != null)
            {
                <p class="payment-method-info">
                    Phương thức: <strong>@Model.Payment.PaymentMethod</strong>
                    @if (!string.IsNullOrEmpty(Model.Payment.VnpayTransactionId))
                    {
                        <span> — Mã GD: @Model.Payment.VnpayTransactionId</span>
                    }
                </p>
            }
        }

        <div class="result-actions">
            <a href="/" class="btn-home">🏠 Về trang chủ</a>
        </div>
    </div>
</div>

<style>
    .result-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    }
    .result-card {
        background: #fff;
        border-radius: 24px;
        padding: 2.5rem 2rem;
        max-width: 580px;
        width: 100%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,.1);
    }
    .result-icon { margin-bottom: 1.5rem; }
    .checkmark { width: 80px; height: 80px; border-radius: 50%; display: block; margin: 0 auto; }
    .checkmark-circle {
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-width: 3;
        stroke-miterlimit: 10;
        stroke: #22c55e;
        animation: stroke .6s cubic-bezier(.65,0,.45,1) forwards;
    }
    .checkmark-check {
        transform-origin: 50% 50%;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        stroke-width: 3;
        stroke: #22c55e;
        animation: stroke .3s cubic-bezier(.65,0,.45,1) .6s forwards;
    }
    @@keyframes stroke {
        100% { stroke-dashoffset: 0; }
    }
    h1 { font-size: 1.75rem; font-weight: 800; color: #15803d; margin: 0 0 .5rem; }
    .result-subtitle { color: #64748b; margin-bottom: 1.5rem; }
    .booking-id-badge {
        background: #dcfce7;
        color: #15803d;
        border-radius: 50px;
        padding: .5rem 1.5rem;
        display: inline-block;
        font-size: .95rem;
        margin-bottom: 1.5rem;
    }
    .ticket-summary {
        background: #f8fafc;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        text-align: left;
        margin-bottom: 1rem;
    }
    .ticket-row {
        display: flex;
        justify-content: space-between;
        padding: .35rem 0;
        font-size: .9rem;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
    }
    .ticket-row:last-child { border-bottom: none; }
    .ticket-label { color: #94a3b8; }
    .seat-list { text-align: left; margin-bottom: 1rem; }
    .seat-list-title { font-weight: 700; color: #1e293b; margin-bottom: .6rem; }
    .seat-ticket-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8fafc;
        border-radius: 10px;
        padding: .7rem 1rem;
        margin-bottom: .5rem;
        font-size: .85rem;
        gap: .5rem;
        flex-wrap: wrap;
    }
    .seat-num { font-weight: 700; color: #1e293b; }
    .seat-type {
        background: #e0e7ff; color: #4f46e5;
        border-radius: 4px; padding: .1rem .4rem;
        font-size: .75rem; margin-left: .4rem;
    }
    .passenger-info { color: #64748b; display: flex; flex-direction: column; gap: .1rem; }
    .seat-price-tag { font-weight: 700; color: #0ea5e9; }
    .payment-total {
        display: flex;
        justify-content: space-between;
        background: #1e293b;
        color: #fff;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 1.1rem;
        margin-bottom: .75rem;
    }
    .payment-total strong { color: #38bdf8; }
    .payment-method-info { color: #94a3b8; font-size: .85rem; margin-bottom: 1.5rem; }
    .result-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .btn-home, .btn-book-more {
        padding: .7rem 1.5rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .9rem;
        text-decoration: none;
        transition: all .2s;
    }
    .btn-home { background: #f1f5f9; color: #475569; }
    .btn-home:hover { background: #e2e8f0; }
    .btn-book-more { background: #22c55e; color: #fff; }
    .btn-book-more:hover { background: #16a34a; transform: translateY(-1px); }
</style>
