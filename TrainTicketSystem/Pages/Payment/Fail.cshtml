@page
@model TrainTicketSystem.Pages.Payment.FailModel
@{
    ViewData["Title"] = "Thanh toán không thành công";
    Layout = "~/Pages/Shared/_CustomerLayout.cshtml";
}

<div class="result-wrapper">
    <div class="result-card fail-card">

        <div class="fail-icon">❌</div>

        <h1>Thanh toán thất bại</h1>
        <p class="result-subtitle">
            @if (Model.Reason == "invalid_signature")
            {
                <text>Phản hồi không hợp lệ từ cổng thanh toán.</text>
            }
            else
            {
                <text>Giao dịch đã bị hủy hoặc không thành công. Ghế đã được giải phóng.</text>
            }
        </p>

        @if (!string.IsNullOrEmpty(Model.Code))
        {
            <div class="error-code">Mã lỗi VNPay: <strong>@Model.Code</strong></div>
        }

        <div class="fail-hint">
            <strong>💡 Lưu ý:</strong> Vé chưa được đặt. Bạn có thể thử lại hoặc chọn ghế khác.
        </div>

        <div class="result-actions">
            <a href="/Schedules" class="btn-retry">🔄 Thử lại</a>
            <a href="/" class="btn-home">🏠 Về trang chủ</a>
        </div>
    </div>
</div>

<style>
    .result-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: linear-gradient(135deg, #fef2f2 0%, #fff1f2 100%);
    }
    .result-card {
        background: #fff;
        border-radius: 24px;
        padding: 2.5rem 2rem;
        max-width: 480px;
        width: 100%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,.1);
    }
    .fail-icon { font-size: 5rem; margin-bottom: 1rem; animation: shake .5s ease; }
    @@keyframes shake {
        0%,100% { transform: translateX(0); }
        20%,60%  { transform: translateX(-8px); }
        40%,80%  { transform: translateX(8px); }
    }
    h1 { font-size: 1.75rem; font-weight: 800; color: #dc2626; margin: 0 0 .5rem; }
    .result-subtitle { color: #64748b; margin-bottom: 1rem; }
    .error-code {
        background: #fef2f2;
        color: #dc2626;
        border-radius: 8px;
        padding: .5rem 1rem;
        font-size: .9rem;
        margin-bottom: 1rem;
        display: inline-block;
    }
    .fail-hint {
        background: #fffbeb;
        border-left: 4px solid #f59e0b;
        border-radius: 8px;
        padding: .875rem 1rem;
        text-align: left;
        font-size: .875rem;
        color: #92400e;
        margin-bottom: 1.5rem;
    }
    .result-actions { display: flex; gap: .75rem; justify-content: center; }
    .btn-retry, .btn-home {
        padding: .7rem 1.5rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .9rem;
        text-decoration: none;
        transition: all .2s;
    }
    .btn-retry { background: #dc2626; color: #fff; }
    .btn-retry:hover { background: #b91c1c; transform: translateY(-1px); }
    .btn-home { background: #f1f5f9; color: #475569; }
    .btn-home:hover { background: #e2e8f0; }
</style>
