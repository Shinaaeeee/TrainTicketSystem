@page
@model TrainTicketSystem.Pages.Seats.Index
@{
    ViewData["Title"] = "Seat Management";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Seat List</h1>
    <button onclick="openModal('createModal')"
            class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors inline-block cursor-pointer shadow-sm">
        Add New Seat
    </button>
</div>

@* ── Thông báo lỗi / thành công ── *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">
        @TempData["ErrorMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-lg text-sm">
        @TempData["SuccessMessage"]
    </div>
}

@* ── Filter bar ── *@
<form method="get" class="flex flex-wrap gap-4 mb-6">
    <select name="FilterTrainId"
            class="border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white text-slate-700 shadow-sm min-w-[200px]"
            asp-items="Model.TrainOptions">
        <option value="">-- All Trains --</option>
    </select>

    <select name="FilterSeatTypeId"
            class="border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white text-slate-700 shadow-sm min-w-[200px]"
            asp-items="Model.SeatTypeOptions">
        <option value="">-- All Seat Types --</option>
    </select>

    <button type="submit"
            class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm">
        Search
    </button>

    @if (Model.FilterTrainId.HasValue || Model.FilterSeatTypeId.HasValue)
    {
        <a asp-page="./Index"
           class="bg-red-50 hover:bg-red-100 border border-red-200 text-red-600 px-5 py-2 rounded-lg text-sm font-medium transition-colors flex items-center shadow-sm">
            Clear
        </a>
    }
</form>

@* ── Table ── *@
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Seat ID</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Train Name</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Seat Number</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Seat Type</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Price Multiplier</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm text-center">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @if (Model.Seats != null && Model.Seats.Any())
            {
                @foreach (var seat in Model.Seats)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="py-4 px-6 text-slate-500 text-sm font-mono">#@seat.SeatId</td>
                        <td class="py-4 px-6 font-medium text-slate-900">@seat.TrainName</td>
                        <td class="py-4 px-6 text-slate-700 font-mono">@seat.SeatNumber</td>
                        <td class="py-4 px-6 text-slate-700">@seat.TypeName</td>
                        <td class="py-4 px-6">
                            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 border border-blue-200">
                                x@(seat.PriceMultiplier.ToString("0.00"))
                            </span>
                        </td>
                        <td class="py-4 px-6 text-center space-x-3">
                            <button onclick="openEditModal(@seat.SeatId, @seat.TrainId, '@seat.SeatNumber', @seat.SeatTypeId)"
                                    class="text-amber-500 hover:text-amber-700 bg-amber-50 hover:bg-amber-100 p-2 rounded-lg transition-colors inline-block"
                                    title="Edit">
                                <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                            </button>
                            <button onclick="openDeleteModal(@seat.SeatId)"
                                    class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors inline-block"
                                    title="Delete">
                                <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="py-10 text-center text-slate-500">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="armchair" class="w-10 h-10 text-slate-300 mb-2"></i>
                            <p>No seats found matching the selected filters.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="px-6 py-4 border-t border-slate-200 bg-white flex flex-wrap items-center justify-between gap-4">
        <p class="text-sm text-slate-600">
            Hiển thị <span class="font-semibold">@Model.Seats.Count</span> trên tổng số <span class="font-semibold">@Model.TotalItems</span> ghế
            @if (Model.FilterTrainId.HasValue || Model.FilterSeatTypeId.HasValue)
            {
                <span class="text-slate-400">— filtered results</span>
            }
        </p>

        @if (Model.TotalPages > 1)
        {
            <div class="flex gap-1">
                @* Nút Previous *@
                @if (Model.PageIndex > 1)
                {
                    <a href="?PageIndex=@(Model.PageIndex - 1)&FilterTrainId=@Model.FilterTrainId&FilterSeatTypeId=@Model.FilterSeatTypeId"
                       class="px-3 py-1 border border-slate-300 rounded text-slate-600 hover:bg-slate-50 text-sm transition-colors">
                        Trước
                    </a>
                }

                @* Vòng lặp in số trang *@
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?PageIndex=@i&FilterTrainId=@Model.FilterTrainId&FilterSeatTypeId=@Model.FilterSeatTypeId"
                       class="px-3 py-1 border rounded text-sm transition-colors @(i == Model.PageIndex ? "bg-slate-800 text-white border-slate-800" : "border-slate-300 text-slate-600 hover:bg-slate-50")">
                        @i
                    </a>
                }

                @* Nút Next *@
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?PageIndex=@(Model.PageIndex + 1)&FilterTrainId=@Model.FilterTrainId&FilterSeatTypeId=@Model.FilterSeatTypeId"
                       class="px-3 py-1 border border-slate-300 rounded text-slate-600 hover:bg-slate-50 text-sm transition-colors">
                        Sau
                    </a>
                }
            </div>
        }
    </div>
</div>

@* ══════════════════════════════════════════════════════
   CREATE MODAL
   ══════════════════════════════════════════════════════ *@
<div id="createModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Add New Seat</h2>
            <button type="button" onclick="closeModal('createModal')" class="text-slate-400 hover:text-slate-600">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Train <span class="text-red-500">*</span></label>
                <select asp-for="CurrentSeat.TrainId" asp-items="Model.TrainOptions"
                        class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Select Train --</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Seat Number <span class="text-red-500">*</span></label>
                <input type="text" asp-for="CurrentSeat.SeatNumber"
                       class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                       placeholder="e.g. A01" required />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Seat Type <span class="text-red-500">*</span></label>
                <select asp-for="CurrentSeat.SeatTypeId" asp-items="Model.SeatTypeOptions"
                        class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Select Type --</option>
                </select>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('createModal')"
                        class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors shadow-sm">
                    Save Seat
                </button>
            </div>
        </form>
    </div>
</div>

@* ══════════════════════════════════════════════════════
   EDIT MODAL
   ══════════════════════════════════════════════════════ *@
<div id="editModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Edit Seat</h2>
            <button type="button" onclick="closeModal('editModal')" class="text-slate-400 hover:text-slate-600">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <form method="post" asp-page-handler="Edit">
            <input type="hidden" id="editSeatId" asp-for="CurrentSeat.SeatId" />
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Train <span class="text-red-500">*</span></label>
                <select id="editTrainId" asp-for="CurrentSeat.TrainId" asp-items="Model.TrainOptions"
                        class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Select Train --</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Seat Number <span class="text-red-500">*</span></label>
                <input type="text" id="editSeatNumber" asp-for="CurrentSeat.SeatNumber"
                       class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Seat Type <span class="text-red-500">*</span></label>
                <select id="editSeatTypeId" asp-for="CurrentSeat.SeatTypeId" asp-items="Model.SeatTypeOptions"
                        class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Select Type --</option>
                </select>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('editModal')"
                        class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-lg font-medium transition-colors shadow-sm">
                    Update Seat
                </button>
            </div>
        </form>
    </div>
</div>

@* ══════════════════════════════════════════════════════
   DELETE MODAL
   ══════════════════════════════════════════════════════ *@
<div id="deleteModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 text-center">
        <div class="mx-auto flex items-center justify-center h-14 w-14 rounded-full bg-red-100 mb-4">
            <i data-lucide="alert-triangle" class="h-7 w-7 text-red-600"></i>
        </div>
        <h2 class="text-xl font-bold text-slate-900 mb-2">Delete Seat?</h2>
        <p class="text-sm text-slate-500 mb-6">Are you sure you want to delete this seat? This action cannot be undone.</p>
        <form method="post" asp-page-handler="Delete">
            <input type="hidden" name="id" id="deleteSeatId" />
            <div class="flex justify-center gap-3">
                <button type="button" onclick="closeModal('deleteModal')"
                        class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors w-1/2">
                    Cancel
                </button>
                <button type="submit"
                        class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-colors shadow-sm w-1/2">
                    Yes, Delete
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(modalId) {
        document.getElementById(modalId).classList.remove('hidden');
        document.getElementById(modalId).classList.add('flex');
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
        document.getElementById(modalId).classList.remove('flex');
    }

    // Điền dữ liệu vào Edit modal khi bấm nút Edit
    function openEditModal(id, trainId, seatNumber, seatTypeId) {
        document.getElementById('editSeatId').value = id;
        document.getElementById('editTrainId').value = trainId;
        document.getElementById('editSeatNumber').value = seatNumber;
        document.getElementById('editSeatTypeId').value = seatTypeId;
        openModal('editModal');
    }

    function openDeleteModal(id) {
        document.getElementById('deleteSeatId').value = id;
        openModal('deleteModal');
    }
</script>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/seatCrudHub")
        .withAutomaticReconnect()
        .build();

    connection.on("SeatChanged", function (action, seatId) {
        console.log(`Seat ${action}: ${seatId}`);
        location.reload();
    });

    connection.start().catch(function (err) {
        console.error("SignalR connection error: ", err.toString());
    });
</script>