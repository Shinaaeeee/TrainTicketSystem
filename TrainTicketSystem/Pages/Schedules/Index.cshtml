@page
@model TrainTicketSystem.Pages.Schedules.IndexModel
@{
    ViewData["Title"] = "Schedule Management";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Schedule List</h1>
    <button onclick="openModal('createModal')" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors inline-block cursor-pointer shadow-sm">
        Create New Schedule
    </button>
</div>

<form method="get" class="flex flex-wrap gap-4 mb-6">
    <div class="flex-1 min-w-[300px]">
        <div class="relative">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-[18px] h-[18px]"></i>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search by train name or station..." class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all shadow-sm" />
        </div>
    </div>

    <button type="submit" class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm">
        Search
    </button>

    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <a href="/Schedules" class="bg-red-50 hover:bg-red-100 border border-red-200 text-red-600 px-5 py-2 rounded-lg text-sm font-medium transition-colors flex items-center shadow-sm">
            Clear
        </a>
    }

    <select class="w-40 border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white text-slate-700 shadow-sm">
        <option value="all">Filter by Train</option>
        <option value="se1">SE1</option>
        <option value="se2">SE2</option>
    </select>
</form>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">ID</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Train</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Route</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Departure Time</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Arrival Time</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Price</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm text-center">Action</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @if (Model.ScheduleList != null && Model.ScheduleList.Any())
            {
                @foreach (var item in Model.ScheduleList)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="py-4 px-6 font-medium text-slate-900">SCH-@item.ScheduleId</td>
                        <td class="py-4 px-6 text-slate-700 font-semibold text-blue-600">@(item.Train?.TrainName ?? "N/A")</td>
                        <td class="py-4 px-6 text-slate-700">
                            @(item.Route != null ? $"{item.Route.StartStation} - {item.Route.EndStation}" : "N/A")
                        </td>
                        <td class="py-4 px-6 text-slate-700">
                            <div class="flex items-center gap-2">
                                <i data-lucide="calendar" class="w-4 h-4 text-slate-400"></i>
                                @(item.DepartureTime?.ToString("dd/MM/yyyy HH:mm"))
                            </div>
                        </td>
                        <td class="py-4 px-6 text-slate-700">
                            <div class="flex items-center gap-2">
                                <i data-lucide="clock" class="w-4 h-4 text-slate-400"></i>
                                @(item.ArrivalTime?.ToString("dd/MM/yyyy HH:mm"))
                            </div>
                        </td>
                        <td class="py-4 px-6 text-slate-700">
                            @if (item.Price != null)
                            {
                                <span class="font-semibold text-emerald-600">@item.Price?.ToString("N0") VNĐ</span>
                            }
                            else
                            {
                                <span class="text-slate-400 italic">Chưa có giá</span>
                            }
                        </td>
                        <td class="py-4 px-6 text-center space-x-3">
                            @{
                                var depStr = item.DepartureTime?.ToString("yyyy-MM-ddTHH:mm");
                                var arrStr = item.ArrivalTime?.ToString("yyyy-MM-ddTHH:mm");
                                var currentPrice = item.Price ?? 0;
                            }
                            <button onclick="openEditModal(@item.ScheduleId, @(item.TrainId), @(item.RouteId), '@depStr', '@arrStr', @currentPrice)" class="text-amber-500 hover:text-amber-700 bg-amber-50 hover:bg-amber-100 p-2 rounded-lg transition-colors inline-block" title="Edit">
                                <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                            </button>
                            <button onclick="openDeleteModal(@item.ScheduleId)" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors inline-block" title="Delete">
                                <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="py-10 text-center text-slate-500">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="calendar-x" class="w-10 h-10 text-slate-300 mb-2"></i>
                            <p>No schedules found.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="px-6 py-4 border-t border-slate-200 bg-white flex items-center justify-between">
        <p class="text-sm text-slate-600">
            Showing <span class="font-semibold">@((Model.CurrentPage - 1) * Model.PageSize + (Model.TotalItems > 0 ? 1 : 0))</span> to
            <span class="font-semibold">@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems))</span> of
            <span class="font-semibold">@Model.TotalItems</span> schedules
        </p>

        <div class="flex items-center gap-2">
            <a href="?SearchTerm=@Model.SearchTerm&p=@(Model.CurrentPage - 1)"
               class="px-3 py-2 border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors @(Model.CurrentPage <= 1 ? "pointer-events-none opacity-50 bg-slate-50" : "")">
                Previous
            </a>
            @{
                int displayPages = Model.TotalPages > 0 ? Model.TotalPages : 1;
                for (int i = 1; i <= displayPages; i++)
                {
                    <a href="?SearchTerm=@Model.SearchTerm&p=@i"
                       class="px-3 py-2 rounded-lg text-sm font-medium transition-colors @(Model.CurrentPage == i ? "bg-blue-600 text-white shadow-sm" : "border border-slate-300 text-slate-700 hover:bg-slate-50")">
                        @i
                    </a>
                }
            }
            <a href="?SearchTerm=@Model.SearchTerm&p=@(Model.CurrentPage + 1)"
               class="px-3 py-2 border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors @(Model.CurrentPage >= Model.TotalPages ? "pointer-events-none opacity-50 bg-slate-50" : "")">
                Next
            </a>
        </div>
    </div>
</div>

<div id="createModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-lg p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Create New Schedule</h2>
            <button type="button" onclick="closeModal('createModal')" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>

        <form method="post" asp-page-handler="Create">
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Select Train <span class="text-red-500">*</span></label>
                    <select asp-for="CurrentSchedule.TrainId" asp-items="Model.TrainOptions" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white" required>
                        <option value="">-- Choose Train --</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Select Route <span class="text-red-500">*</span></label>
                    <select asp-for="CurrentSchedule.RouteId" asp-items="Model.RouteOptions" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white" required>
                        <option value="">-- Choose Route --</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Departure Time <span class="text-red-500">*</span></label>
                    <input type="datetime-local" asp-for="CurrentSchedule.DepartureTime" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
                    <span asp-validation-for="CurrentSchedule.DepartureTime" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Arrival Time <span class="text-red-500">*</span></label>
                    <input type="datetime-local" asp-for="CurrentSchedule.ArrivalTime" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
                    <span asp-validation-for="CurrentSchedule.ArrivalTime" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-700 mb-1">Ticket Price (VNĐ) <span class="text-red-500">*</span></label>
                <input type="number" asp-for="CurrentSchedule.Price" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="VD: 150000" min="0" required />
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('createModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors shadow-sm">Save Schedule</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-lg p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Edit Schedule</h2>
            <button type="button" onclick="closeModal('editModal')" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>

        <form method="post" asp-page-handler="Edit">
            <input type="hidden" id="editScheduleId" asp-for="CurrentSchedule.ScheduleId" />

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Select Train <span class="text-red-500">*</span></label>
                    <select id="editTrainId" asp-for="CurrentSchedule.TrainId" asp-items="Model.TrainOptions" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white" required></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Select Route <span class="text-red-500">*</span></label>
                    <select id="editRouteId" asp-for="CurrentSchedule.RouteId" asp-items="Model.RouteOptions" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white" required></select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Departure Time <span class="text-red-500">*</span></label>
                    <input type="datetime-local" id="editDepTime" asp-for="CurrentSchedule.DepartureTime" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Arrival Time <span class="text-red-500">*</span></label>
                    <input type="datetime-local" id="editArrTime" asp-for="CurrentSchedule.ArrivalTime" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-700 mb-1">Ticket Price (VNĐ) <span class="text-red-500">*</span></label>
                <input type="number" id="editPrice" asp-for="CurrentSchedule.Price" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required min="0" />
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('editModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-lg font-medium transition-colors shadow-sm">Update Schedule</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 text-center">
        <div class="mx-auto flex items-center justify-center h-14 w-14 rounded-full bg-red-100 mb-4">
            <i data-lucide="alert-triangle" class="h-7 w-7 text-red-600"></i>
        </div>
        <h2 class="text-xl font-bold text-slate-900 mb-2">Delete Schedule?</h2>
        <p class="text-sm text-slate-500 mb-6">Are you sure you want to delete this schedule? This action cannot be undone.</p>

        <form method="post" asp-page-handler="Delete">
            <input type="hidden" name="id" id="deleteScheduleId" />
            <div class="flex justify-center gap-3">
                <button type="button" onclick="closeModal('deleteModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors w-1/2">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-colors shadow-sm w-1/2">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(modalId) {
        document.getElementById(modalId).classList.remove('hidden');
        document.getElementById(modalId).classList.add('flex');
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
        document.getElementById(modalId).classList.remove('flex');
    }

    function openEditModal(id, trainId, routeId, depTime, arrTime, price) {
        document.getElementById('editScheduleId').value = id;
        document.getElementById('editTrainId').value = trainId;
        document.getElementById('editRouteId').value = routeId;
        document.getElementById('editDepTime').value = depTime;
        document.getElementById('editArrTime').value = arrTime;
        document.getElementById('editPrice').value = price;
        openModal('editModal');
    }

    function openDeleteModal(id) {
        document.getElementById('deleteScheduleId').value = id;
        openModal('deleteModal');
    }
</script>

@if (ViewData["ShowCreateModal"] as bool? == true)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            openModal('createModal');
        });
    </script>
}

<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/scheduleHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ScheduleChanged", function (action, scheduleId) {
        console.log(`Schedule ${action}: ${scheduleId}`);
        location.reload();
    });

    connection.start().catch(function (err) {
        console.error("SignalR connection error: ", err.toString());
    });
</script>
