@page
@model TrainTicketSystem.Pages.UserProfile.ProfileModel
@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Pages/Shared/UserLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">

        <div class="text-center mb-4">
            <div class="bg-dark text-white rounded-circle d-inline-flex align-items-center justify-content-center"
                 style="width:72px;height:72px;font-size:2rem;">
                <i class="bi bi-person-fill"></i>
            </div>
            <h4 class="mt-2 mb-0">@Model.UserInfo?.FullName</h4>
            <small class="text-muted">@@@Model.UserInfo?.Username</small>
        </div>

        @* ── Success Toast ── *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center" role="alert" id="successAlert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        @* ── Profile Info (read-only view) ── *@
        @if (!Model.Edit)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Profile Information</span>
                    <a href="?Edit=true" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>Edit
                    </a>
                </div>
                <div class="card-body">
                    <div class="mb-3 row">
                        <label class="col-sm-4 col-form-label text-muted">Username</label>
                        <div class="col-sm-8">
                            <p class="form-control-plaintext fw-medium">@Model.UserInfo?.Username</p>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label class="col-sm-4 col-form-label text-muted">Full Name</label>
                        <div class="col-sm-8">
                            <p class="form-control-plaintext">@(Model.UserInfo?.FullName ?? "—")</p>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label class="col-sm-4 col-form-label text-muted">Email</label>
                        <div class="col-sm-8">
                            <p class="form-control-plaintext">@(Model.UserInfo?.Email ?? "—")</p>
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-4 col-form-label text-muted">Phone</label>
                        <div class="col-sm-8">
                            <p class="form-control-plaintext">@(Model.UserInfo?.Phone ?? "—")</p>
                        </div>
                    </div>
                    <div class="mb-0 row">
                        <label class="col-sm-4 col-form-label text-muted">Role</label>
                        <div class="col-sm-8">
                            <p class="form-control-plaintext">
                                <span class="badge bg-secondary">@(Model.UserInfo?.Role ?? "User")</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* ── Edit Form ── *@
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <span class="fw-semibold">Edit Profile</span>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label text-muted">Username</label>
                            <input class="form-control" value="@Model.UserInfo?.Username" readonly disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.FullName" class="form-label text-muted">Full Name</label>
                            <input asp-for="Input.FullName" class="form-control" />
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label text-muted">Email</label>
                            <input asp-for="Input.Email" class="form-control" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Phone" class="form-label text-muted">Phone</label>
                            <input asp-for="Input.Phone" class="form-control" />
                            <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-check-lg me-1"></i>Save Changes
                            </button>
                            <a href="/UserProfile/Profile" class="btn btn-outline-secondary flex-fill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        }

    </div>
</div>

@* Auto-hide success alert after 3 seconds *@
<script>
        (function () {
            var alert = document.getElementById('successAlert');
            if (alert) {
                setTimeout(function () {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(function () { alert.remove(); }, 500);
                }, 3000);
            }
    })();
</script>