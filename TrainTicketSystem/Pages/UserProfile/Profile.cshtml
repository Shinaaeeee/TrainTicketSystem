@page
@model TrainTicketSystem.Pages.UserProfile.ProfileModel
@{
    ViewData["HideNavbar"] = true;
}
@{
    ViewData["Title"] = "User Profile";
}

<style>
    
    body {
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        min-height: 100vh;
        font-family: 'Segoe UI', -apple-system, sans-serif;
    }

    /* Center */
    .container {
        margin-top: 80px;
    }

    /* Card */
    .profile-card {
        max-width: 500px;
        margin: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 8px 30px rgba(0,0,0,.08);
        overflow: hidden;
        background: #fff;
    }

    
    .card-header {
        background: linear-gradient(135deg, #3b82f6, #6366f1) !important;
        border: none;
        font-weight: 700;
    }

    /* Input */
    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #3b82f6;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(59,130,246,.15);
        }

    /* Label */
    label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #475569;
    }


    .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        border: none;
        border-radius: 10px;
        font-weight: 700;
        padding: 10px;
        transition: 0.2s;
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(59,130,246,.3);
        }

    /* Message */
    .text-success {
        font-weight: 600;
    }

    .text-danger {
        font-size: 0.8rem;
    }
</style>

<div class="container mt-5">

    <div class="card profile-card">

        <div class="card-header bg-dark text-white text-center">
            <h3>👤 User Profile</h3>
        </div>

        <div class="card-body">

            <form method="post">

                <div class="mb-3">
                    <label>Username</label>
                    <input class="form-control"
                           value="@Model.User?.Username"
                           readonly />
                </div>

                <div class="mb-3">
                    <label>Full Name</label>
                    <input asp-for="User.FullName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="User.Email" class="form-control" />
                    <span asp-validation-for="User.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Phone</label>
                    <input asp-for="User.Phone" class="form-control" />
                    <span asp-validation-for="User.Phone" class="text-danger"></span>
                </div>

                <button class="btn btn-primary w-100">
                    Update Profile
                </button>

            </form>

            <p class="text-success text-center mt-3">
                @ViewData["Message"]
            </p>

        </div>

    </div>
