@page
@model TrainTicketSystem.Pages.Admin.Revenue.IndexModel
@{
    ViewData["Title"] = "Thống kê doanh thu";
    Layout = "_Layout";
    var r = Model.Revenue;
}

<div class="container-fluid px-4 py-4">

    <!-- ========== PAGE HEADER ========== -->
    <div class="mb-4">
        <h2 class="fw-bold mb-0">📊 Thống kê doanh thu</h2>
        <small class="text-muted">
            @if (Model.FromDate.HasValue || Model.ToDate.HasValue)
            {
                <span>Lọc:
                    @(Model.FromDate?.ToString("dd/MM/yyyy") ?? "...")
                    →
                    @(Model.ToDate?.ToString("dd/MM/yyyy") ?? "...")
                </span>
            }
            else
            {
                <span>Toàn bộ thời gian</span>
            }
        </small>
    </div>

    <!-- ========== DATE FILTER ========== -->
    <form method="get" class="row g-2 mb-4 align-items-end">
        <div class="col-md-3">
            <label class="form-label text-muted small">Từ ngày</label>
            <input type="date" name="FromDate"
                   value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label text-muted small">Đến ngày</label>
            <input type="date" name="ToDate"
                   value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Xem</button>
            <a href="/Admin/Revenue" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    <!-- ========== SUMMARY CARDS ========== -->
    <div class="row g-3 mb-4">
        <!-- Total Revenue -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0d6efd !important;">
                <div class="card-body">
                    <div class="text-muted small mb-1">Tổng doanh thu</div>
                    <div class="fs-4 fw-bold text-primary">@r.TotalRevenue.ToString("N0") ₫</div>
                </div>
            </div>
        </div>
        <!-- Total Bookings -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Tổng đơn đặt vé</div>
                    <div class="fs-4 fw-bold">@r.TotalBookings</div>
                </div>
            </div>
        </div>
        <!-- Paid -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Đã thanh toán</div>
                    <div class="fs-4 fw-bold text-success">@r.PaidBookings</div>
                </div>
            </div>
        </div>
        <!-- Pending -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Đang chờ</div>
                    <div class="fs-4 fw-bold text-warning">@r.PendingBookings</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- ========== REVENUE BY ROUTE ========== -->
        <div class="col-md-7">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold">🚂 Doanh thu theo tuyến đường</div>
                <div class="card-body p-0">
                    @if (!r.ByRoute.Any())
                    {
                        <p class="p-3 text-muted mb-0">Không có dữ liệu.</p>
                    }
                    else
                    {
                        // Find the max revenue to calculate bar width %
                        var maxRevenue = r.ByRoute.Max(x => x.TotalRevenue);

                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tuyến</th>
                                    <th class="text-center">Số đơn</th>
                                    <th>Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var route in r.ByRoute)
                                {
                                    // Calculate bar fill % for visual indicator
                                    var pct = maxRevenue > 0
                                        ? (int)(route.TotalRevenue / maxRevenue * 100)
                                        : 0;

                                    <tr>
                                        <td>@route.StartStation → @route.EndStation</td>
                                        <td class="text-center">@route.TotalBookings</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <!-- Mini inline bar chart -->
                                                <div style="flex: 1; background: #e9ecef; border-radius: 4px; height: 8px;">
                                                    <div style="width: @pct%; background: #0d6efd; height: 100%; border-radius: 4px;"></div>
                                                </div>
                                                <span class="fw-semibold" style="min-width: 100px; text-align: right;">
                                                    @route.TotalRevenue.ToString("N0") ₫
                                                </span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- ========== REVENUE BY MONTH ========== -->
        <div class="col-md-5">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold">📅 Doanh thu theo tháng</div>
                <div class="card-body p-0">
                    @if (!r.ByMonth.Any())
                    {
                        <p class="p-3 text-muted mb-0">Không có dữ liệu.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tháng</th>
                                    <th class="text-center">Giao dịch</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in r.ByMonth)
                                {
                                    <tr>
                                        <td>@m.Label</td>
                                        <td class="text-center">@m.TotalPayments</td>
                                        <td class="text-end fw-semibold text-success">
                                            @m.TotalRevenue.ToString("N0") ₫
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
