@page
@model TrainTicketSystem.Pages.Routes.IndexModel
@{
    ViewData["Title"] = "Route Management";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Route List</h1>
    <button onclick="openModal('createModal')" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors inline-block cursor-pointer shadow-sm">
        Create New Route
    </button>
</div>

<form method="get" class="flex flex-wrap gap-4 mb-6">
    <div class="flex-1 min-w-[300px]">
        <div class="relative">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-[18px] h-[18px]"></i>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search by origin or destination..." class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all shadow-sm" />
        </div>
    </div>

    <button type="submit" class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm">
        Search
    </button>

    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <a href="/Routes" class="bg-red-50 hover:bg-red-100 border border-red-200 text-red-600 px-5 py-2 rounded-lg text-sm font-medium transition-colors flex items-center shadow-sm">
            Clear
        </a>
    }

    <select class="w-40 border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white text-slate-700 shadow-sm">
        <option value="all">Filter by Status</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
    </select>

    <select class="w-40 border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white text-slate-700 shadow-sm">
        <option value="all">Filter by Distance</option>
        <option value="short">Short (0-500 km)</option>
        <option value="medium">Medium (500-1000 km)</option>
        <option value="long">Long (1000+ km)</option>
    </select>
</form>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Origin</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Destination</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Distance</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Duration</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm">Status</th>
                <th class="py-4 px-6 font-semibold text-slate-700 text-sm text-center">Action</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @if (Model.RouteList != null && Model.RouteList.Any())
            {
                @foreach (var item in Model.RouteList)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="py-4 px-6 font-medium text-slate-900">@item.StartStation</td>
                        <td class="py-4 px-6 text-slate-700">@item.EndStation</td>
                        <td class="py-4 px-6 text-slate-700">@item.DistanceKm km</td>
                        <td class="py-4 px-6 text-slate-700">
                            @(Math.Round((double)(item.DistanceKm ?? 0) / 60, 1)) hours
                        </td>
                        <td class="py-4 px-6">
                            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700 border border-green-200">Active</span>
                        </td>
                        <td class="py-4 px-6 text-center space-x-3">
                            <button onclick="openEditModal(@item.RouteId, '@item.StartStation', '@item.EndStation', @item.DistanceKm)" class="text-amber-500 hover:text-amber-700 bg-amber-50 hover:bg-amber-100 p-2 rounded-lg transition-colors inline-block" title="Edit">
                                <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                            </button>
                            <button onclick="openDeleteModal(@item.RouteId)" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors inline-block" title="Delete">
                                <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="py-10 text-center text-slate-500">
                        <div class="flex flex-col items-center justify-center">
                            <i data-lucide="map" class="w-10 h-10 text-slate-300 mb-2"></i>
                            <p>No routes found matching your criteria.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="px-6 py-4 border-t border-slate-200 bg-white flex items-center justify-between">
        <p class="text-sm text-slate-600">
            Showing
            <span class="font-semibold">@((Model.CurrentPage - 1) * Model.PageSize + (Model.TotalItems > 0 ? 1 : 0))</span> to
            <span class="font-semibold">@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems))</span> of
            <span class="font-semibold">@Model.TotalItems</span> routes
        </p>

        <div class="flex items-center gap-2">
            <a href="?SearchTerm=@Model.SearchTerm&p=@(Model.CurrentPage - 1)"
               class="px-3 py-2 border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors @(Model.CurrentPage <= 1 ? "pointer-events-none opacity-50 bg-slate-50" : "")">
                Previous
            </a>

            @{
                int displayPages = Model.TotalPages > 0 ? Model.TotalPages : 1;
                for (int i = 1; i <= displayPages; i++)
                {
                    <a href="?SearchTerm=@Model.SearchTerm&p=@i"
                       class="px-3 py-2 rounded-lg text-sm font-medium transition-colors @(Model.CurrentPage == i ? "bg-blue-600 text-white shadow-sm" : "border border-slate-300 text-slate-700 hover:bg-slate-50")">
                        @i
                    </a>
                }
            }

            <a href="?SearchTerm=@Model.SearchTerm&p=@(Model.CurrentPage + 1)"
               class="px-3 py-2 border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors @(Model.CurrentPage >= Model.TotalPages ? "pointer-events-none opacity-50 bg-slate-50" : "")">
                Next
            </a>
        </div>
    </div>
</div>

<div id="createModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Create New Route</h2>
            <button type="button" onclick="closeModal('createModal')" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Origin (Start Station) <span class="text-red-500">*</span></label>
                <input type="text" asp-for="CurrentRoute.StartStation" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Hanoi" required />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Destination (End Station) <span class="text-red-500">*</span></label>
                <input type="text" asp-for="CurrentRoute.EndStation" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Da Nang" required />
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-700 mb-1">Distance (km) <span class="text-red-500">*</span></label>
                <input type="number" asp-for="CurrentRoute.DistanceKm" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. 700" required />
            </div>
            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('createModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors shadow-sm">Save Route</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Edit Route</h2>
            <button type="button" onclick="closeModal('editModal')" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>
        <form method="post" asp-page-handler="Edit">
            <input type="hidden" id="editRouteId" asp-for="CurrentRoute.RouteId" />
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Origin (Start Station) <span class="text-red-500">*</span></label>
                <input type="text" id="editStartStation" asp-for="CurrentRoute.StartStation" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1">Destination (End Station) <span class="text-red-500">*</span></label>
                <input type="text" id="editEndStation" asp-for="CurrentRoute.EndStation" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-slate-700 mb-1">Distance (km) <span class="text-red-500">*</span></label>
                <input type="number" id="editDistance" asp-for="CurrentRoute.DistanceKm" class="w-full border border-slate-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeModal('editModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-lg font-medium transition-colors shadow-sm">Update Route</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50 transition-opacity backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 text-center">
        <div class="mx-auto flex items-center justify-center h-14 w-14 rounded-full bg-red-100 mb-4">
            <i data-lucide="alert-triangle" class="h-7 w-7 text-red-600"></i>
        </div>
        <h2 class="text-xl font-bold text-slate-900 mb-2">Delete Route?</h2>
        <p class="text-sm text-slate-500 mb-6">Are you sure you want to delete this route? This action cannot be undone.</p>

        <form method="post" asp-page-handler="Delete">
            <input type="hidden" name="id" id="deleteRouteId" />
            <div class="flex justify-center gap-3">
                <button type="button" onclick="closeModal('deleteModal')" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors w-1/2">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-colors shadow-sm w-1/2">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(modalId) {
        document.getElementById(modalId).classList.remove('hidden');
        document.getElementById(modalId).classList.add('flex');
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
        document.getElementById(modalId).classList.remove('flex');
    }

    function openEditModal(id, start, end, distance) {
        document.getElementById('editRouteId').value = id;
        document.getElementById('editStartStation').value = start;
        document.getElementById('editEndStation').value = end;
        document.getElementById('editDistance').value = distance;
        openModal('editModal');
    }

    function openDeleteModal(id) {
        document.getElementById('deleteRouteId').value = id;
        openModal('deleteModal');
    }
</script>